{
  "name": "opencode-gaslight",
  "version": "0.1.0",
  "description": "OpenCode TUI plugin to edit assistant responses and thinking in-place, rewriting session history for future context",
  "type": "module",
  "exports": {
    ".": {
      "import": "./tui.tsx"
    },
    "./tui": {
      "import": "./tui.tsx"
    }
  },
  "files": [
    "tui.tsx",
    "README.md"
  ],
  "scripts": {
    "check": "bun -e \"import('./tui.tsx').then(() => console.log('plugin import ok'))\""
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tui",
    "gaslight",
    "edit",
    "llm",
    "session",
    "slash-command"
  ],
  "author": "Adam Hassan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adamkadaban/opencode-gaslight.git"
  },
  "bugs": {
    "url": "https://github.com/Adamkadaban/opencode-gaslight/issues"
  },
  "homepage": "https://github.com/Adamkadaban/opencode-gaslight#readme",
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "@opentui/core": "latest",
    "@opentui/solid": "latest",
    "solid-js": "^1.9.0"
  }
}
